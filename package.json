{
  "name": "hantamap",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Hantamap v1 static public-health intelligence dashboard.",
  "scripts": {
    "dev": "next dev -p 4173",
    "build": "next build",
    "start": "next start -p 4173",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "validate:data": "node --experimental-strip-types scripts/validate-data.ts",
    "build:locations": "node --experimental-strip-types scripts/build-location-index.ts",
    "refresh:data": "node --experimental-strip-types scripts/refresh-hantavirus-data.ts",
    "generate:digest": "node --experimental-strip-types scripts/refresh-hantavirus-data.ts --digest-only"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  }
}
